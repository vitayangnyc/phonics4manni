<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>拼讀翻翻樂</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Noto+Sans+TC:wght=400;700;900&display=swap');
    
    body {
      font-family: 'Noto Sans TC', 'Fredoka One', sans-serif;
    }

    /* 3D 翻牌動畫效果 */
    .flap-container {
      perspective: 1000px;
    }
    
    .flap-card {
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      transform-style: preserve-3d;
    }

    .flap-card.flip-active {
      transform: rotateX(-180deg);
    }

    .flap-front {
      backface-visibility: hidden;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }

    /* 模擬行李箱/翻板時鐘的中間分界線 */
    .split-line {
      position: absolute;
      left: 0;
      right: 0;
      height: 2px;
      background-color: rgba(15, 23, 42, 0.8);
      top: 50%;
      transform: translateY(-50%);
      z-index: 10;
    }

    /* 可愛跳動動畫 */
    @keyframes bounce-slow {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .animate-bounce-slow {
      animation: bounce-slow 2s infinite;
    }
  </style>
</head>
<body class="bg-gradient-to-br from-indigo-50 via-purple-50 to-pink-100 min-h-screen text-slate-800 pb-12">

  <!-- 全螢幕撒花 Canvas -->
  <canvas id="confetti-canvas" class="fixed inset-0 pointer-events-none z-50 w-full h-full"></canvas>

  <!-- 頂部導航欄 -->
