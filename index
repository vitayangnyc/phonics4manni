  <!-- JavaScript 邏輯控制 -->
  <script>
    // 10 個核心單字設定 (切分為 Left 和 Right 部分)
    const targetWords = [
      { id: 1, left: "lun", right: "ch", full: "lunch", translation: "午餐", emoji: "🍱", hint: "中午吃的那餐飯" },
      { id: 2, left: "wh", right: "en", full: "when", translation: "當...的時候", emoji: "⏰", hint: "詢問「時間」的專用詞" },
      { id: 3, left: "th", right: "is", full: "this", translation: "這個", emoji: "👇", hint: "指代手邊距離很近的人或東西" },
      { id: 4, left: "sh", right: "op", full: "shop", translation: "商店", emoji: "🏪", hint: "買文具、零食或玩具去的地方" },
      { id: 5, left: "gra", right: "ph", full: "graph", translation: "圖表", emoji: "📈", hint: "用長條圖或折線圖代表資料的圖" },
      { id: 6, left: "wh", right: "ite", full: "white", translation: "白色", emoji: "⬜", hint: "跟雲或牛奶一樣乾淨的顏色" },
      { id: 7, left: "tee", right: "th", full: "teeth", translation: "牙齒", emoji: "🦷", hint: "吃東西時用來咬碎食物的地方" },
      { id: 8, left: "ph", right: "one", full: "phone", translation: "電話", emoji: "📱", hint: "可以用來傳簡訊或打通話的裝置" },
      { id: 9, left: "ch", right: "urch", full: "church", translation: "教堂", emoji: "⛪", hint: "屋頂有十字架，做禮拜的神聖地方" },
      { id: 10, left: "ch", right: "air", full: "chair", translation: "椅子", emoji: "🪑", hint: "課堂上每位同學屁股坐的家具" }
    ];

    // 所有不重複的左半部發音組合
    const leftList = ["lun", "wh", "th", "sh", "gra", "tee", "ph", "ch"];
    // 所有不重複的右半部發音組合
    const rightList = ["ch", "en", "is", "op", "ph", "ite", "th", "one", "urch", "air"];

    // 遊戲運行狀態
    let currentLeftIndex = 7; // 預設 ch
    let currentRightIndex = 9; // 預設 air -> chair
    let gameMode = 'challenge'; // 預設為 'challenge' (看圖猜字)，不提供 'free'
    let audioGuideEnabled = true; // 語音助手開關

    // 儲存不同模式下完成的單字ID
    let challengeCompletedSet = new Set();
    let listeningCompletedSet = new Set();

    // 關卡模式狀態
    let challengeWordIndex = 0; // 闖關索引
    let challengeList = []; // 題目庫

    // 聽力模式狀態
    let listeningWordIndex = 0;
    let listeningList = [];

    // 音訊播放器 (Web Audio API)
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

    // 產生電子合成音效 (不需加載外部媒體檔案)
    function playBeep(frequency, duration, type = 'sine', volume = 0.1) {
      try {
        if (audioCtx.state === 'suspended') {
          audioCtx.resume();
        }
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = type;
        osc.frequency.setValueAtTime(frequency, audioCtx.currentTime);
        gain.gain.setValueAtTime(volume, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + duration);
      } catch (e) {
        console.log("音效生成失敗：", e);
      }
    }

    // 機械翻牌「喀嗒」音
    function playFlipSound() {
      playBeep(800, 0.05, 'triangle', 0.15);
      setTimeout(() => playBeep(400, 0.03, 'sine', 0.1), 20);
    }

    // 單字配對成功和弦
    function playSuccessSound() {
      const notes = [261.63, 329.63, 392.00, 523.25]; // C4, E4, G4, C5
      notes.forEach((freq, idx) => {
        setTimeout(() => {
          playBeep(freq, 0.2, 'triangle', 0.25);
        }, idx * 100);
      });
    }

    // 全滿貫通關勝利音效
    function playVictorySound() {
      const notes = [523.25, 523.25, 523.25, 523.25, 659.25, 587.33, 659.25, 783.99];
      const durations = [0.15, 0.15, 0.15, 0.3, 0.15, 0.15, 0.15, 0.6];
      let delay = 0;
      notes.forEach((freq, idx) => {
        setTimeout(() => {
          playBeep(freq, durations[idx], 'triangle', 0.25);
        }, delay);
        delay += durations[idx] * 1000 + 50;
      });
    }

    // 初始化加載
    window.onload = function() {
      initGame();
      updateFlapDisplay(false); // 初始渲染，不自動播放音效
      setGameMode('challenge'); // 預設進度
    };

    // 初始化狀態
    function initGame() {
      // 複製並洗牌挑戰與聽力列表
      challengeList = [...targetWords].sort(() => Math.random() - 0.5);
      listeningList = [...targetWords].sort(() => Math.random() - 0.5);

      // 綁定字卡點擊(一下)發音事件
      document.getElementById('left-card').addEventListener('click', onLeftCardClick);
      document.getElementById('right-card').addEventListener('click', onRightCardClick);
      document.getElementById('assembled-card').addEventListener('click', onBottomCardClick);
      document.getElementById('btn-random-word').addEventListener('click', randomizeToValidWord);
    }

    // 點擊左卡處理（單擊發音）
    function onLeftCardClick() {
      speakLeftCard();
    }

    // 點擊右卡處理（單擊發音）
    function onRightCardClick() {
      speakRightCard();
    }

    // 點擊底部黑框處理（單擊發音）
    function onBottomCardClick() {
      triggerSynthesisSpeech();
    }

    // 隨機換成10個指定考題單字之一，並置換上面的 onset 與 rime
    function randomizeToValidWord() {
      const randomIndex = Math.floor(Math.random() * targetWords.length);
      const target = targetWords[randomIndex];
      
      const leftIdx = leftList.indexOf(target.left);
      const rightIdx = rightList.indexOf(target.right);

      if (leftIdx !== -1 && rightIdx !== -1) {
        currentLeftIndex = leftIdx;
        currentRightIndex = rightIdx;
        
        playFlipSound();
        triggerCardAnimation('left-card');
        triggerCardAnimation('right-card');
        
        // 更新顯示並播放完整發音
        updateFlapDisplay(true);
      }
    }

    // 翻轉左卡
    function flipLeft(direction) {
      if (direction === 'up') {
        currentLeftIndex = (currentLeftIndex - 1 + leftList.length) % leftList.length;
      } else {
        currentLeftIndex = (currentLeftIndex + 1) % leftList.length;
      }
      playFlipSound();
      triggerCardAnimation('left-card');
      updateFlapDisplay(false); // 僅切換，不自動播放整詞
      speakLeftCard(); // 播放切換後的音素
    }

    // 翻轉右卡
    function flipRight(direction) {
      if (direction === 'up') {
        currentRightIndex = (currentRightIndex - 1 + rightList.length) % rightList.length;
      } else {
        currentRightIndex = (currentRightIndex + 1) % rightList.length;
      }
      playFlipSound();
      triggerCardAnimation('right-card');
      updateFlapDisplay(false); // 僅切換，不自動播放整詞
      speakRightCard(); // 播放切換後的音素
    }

    // 卡片3D翻轉震動動畫
    function triggerCardAnimation(cardId) {
      const card = document.getElementById(cardId);
      card.classList.add('flip-active');
      setTimeout(() => {
        card.classList.remove('flip-active');
      }, 250);
    }

    // 取得自然拼讀輔助讀音，防止雙字母被拆開唸
    function getPhoneticSpelling(part, position) {
      const leftMap = {
        "lun": "lun",
        "wh": "wuh",
        "th": "thuh",
        "sh": "shuh",
        "gra": "grah",
        "tee": "tee",
        "ph": "fuh",
        "ch": "chuh"
      };

      const rightMap = {
        "ch": "chuh",
        "en": "en",
        "is": "is",
        "op": "op",
        "ph": "fuh",
        "ite": "ite",
        "th": "thuh",
        "one": "own",
        "urch": "urch",
        "air": "air"
      };

      const lowerPart = part.toLowerCase();
      if (position === 'left') {
        return leftMap[lowerPart] || part;
      } else {
        return rightMap[lowerPart] || part;
      }
    }

    // 更新翻板文字與判斷配對
    function updateFlapDisplay(allowSpeech = true) {
      const leftPart = leftList[currentLeftIndex];
      const rightPart = rightList[currentRightIndex];
      const blended = leftPart + rightPart;

      document.getElementById('left-text').innerText = leftPart;
      document.getElementById('right-text').innerText = rightPart;
      document.getElementById('assembled-word').innerText = blended;

      // 檢查是否拼對 10 個核心單字之一
      const matchedWord = targetWords.find(w => w.full === blended);
      const meaningEl = document.getElementById('assembled-meaning');
      const statusEl = document.getElementById('match-status');
      const displayEl = document.getElementById('match-display');

      if (matchedWord) {
        // 拼字成功！
        meaningEl.innerText = `${matchedWord.emoji} ${matchedWord.translation}`;
        statusEl.innerHTML = `🎉 BINGO! 100分單字！`;
        statusEl.classList.remove('hidden');
        
        displayEl.className = "bg-green-50 border-2 border-green-300 rounded-2xl p-6 text-center transition-all duration-300 min-h-[180px] flex flex-col justify-center items-center scale-105 shadow-md";

        // 當按到可以拼成一個字的時候，直接把單字唸出來
        if (allowSpeech) {
          speakPhonics(matchedWord.full);
        }

        // 更新進度與統計
        if (gameMode === 'challenge') {
          const target = challengeList[challengeWordIndex];
          if (blended === target.full) {
            if (!challengeCompletedSet.has(matchedWord.id)) {
              challengeCompletedSet.add(matchedWord.id);
              playSuccessSound();
              createConfettiExplosion();
            }
            updateChecklistUI();
            
            // 拼對自動推進
            setTimeout(() => {
              nextChallenge();
            }, 2500);
          }
        } else if (gameMode === 'listening') {
          const target = listeningList[listeningWordIndex];
          if (blended === target.full) {
            if (!listeningCompletedSet.has(matchedWord.id)) {
              listeningCompletedSet.add(matchedWord.id);
              playSuccessSound();
              createConfettiExplosion();
            }
            updateChecklistUI();
            
            setTimeout(() => {
              nextListening();
            }, 2500);
          }
        }

      } else {
        // 未配對成功
        meaningEl.innerText = "探索發音組合中...";
        statusEl.classList.add('hidden');
        displayEl.className = "bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl p-6 text-center transition-all duration-300 min-h-[180px] flex flex-col justify-center items-center";
      }
    }

    // 播放左卡 onset 的聲音
    function speakLeftCard() {
      const leftPart = leftList[currentLeftIndex];
      const phoneticLeft = getPhoneticSpelling(leftPart, 'left');
      speakSingleSound(phoneticLeft);
    }

    // 播放右卡 rime 的聲音
    function speakRightCard() {
      const rightPart = rightList[currentRightIndex];
      const phoneticRight = getPhoneticSpelling(rightPart, 'right');
      speakSingleSound(phoneticRight);
    }

    // 播放單一發音
    function speakSingleSound(text) {
      if (!('speechSynthesis' in window)) return;
      window.speechSynthesis.cancel();
      const speed = parseFloat(document.getElementById('voice-speed').value) || 0.7;
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = 'en-US';
      utter.rate = speed - 0.1; // 稍微放慢
      window.speechSynthesis.speak(utter);
    }

    // 直接唸出完整單字
    function speakPhonics(full) {
      if (!('speechSynthesis' in window)) return;
      window.speechSynthesis.cancel(); // 先切斷之前的語音

      const speed = parseFloat(document.getElementById('voice-speed').value) || 0.7;
      const utterFull = new SpeechSynthesisUtterance(full);
      utterFull.lang = 'en-US';
      utterFull.rate = speed;
      window.speechSynthesis.speak(utterFull);
    }

    // 播放自訂引導語音
    function speakCustomText(text, lang = 'zh-TW') {
      if (!('speechSynthesis' in window)) return;
      window.speechSynthesis.cancel();
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = lang;
      utter.rate = 0.95;
      window.speechSynthesis.speak(utter);
    }

    // 切換語音助手
    function toggleAudioGuide() {
      audioGuideEnabled = !audioGuideEnabled;
      const btn = document.getElementById('btn-guide-toggle');
      if (audioGuideEnabled) {
        btn.innerText = "📢 語音助手：開啟";
        btn.className = "font-bold text-indigo-600 hover:text-indigo-800 transition";
        speakCustomText("哈囉！我會帶你一起練習單字發音喔！");
      } else {
        btn.innerText = "🔇 語音助手：關閉";
        btn.className = "font-bold text-slate-500 hover:text-slate-700 transition";
      }
    }

    // 主動手動發音
    function triggerSynthesisSpeech() {
      const leftPart = leftList[currentLeftIndex];
      const rightPart = rightList[currentRightIndex];
      const blended = leftPart + rightPart;
      
      speakPhonics(blended);
    }

    // 更新進度板 UI
    function updateChecklistUI() {
      const buttons = document.getElementsByClassName('word-badge-btn');
      const starBadges = document.getElementsByClassName('star-badge');
      const activeSet = (gameMode === 'challenge') ? challengeCompletedSet : listeningCompletedSet;
      
      targetWords.forEach((word, index) => {
        const isDone = activeSet.has(word.id);
        const btn = buttons[index];
        const star = starBadges[index];

        if (isDone) {
          btn.className = "word-badge-btn flex items-center justify-between p-2.5 rounded-xl bg-indigo-905 border-2 border-indigo-500/50 bg-indigo-950/60 transition text-left group text-white";
          star.innerText = "⭐";
          star.className = "star-badge text-amber-400 font-bold text-sm scale-110 animate-pulse";
        } else {
          btn.className = "word-badge-btn flex items-center justify-between p-2.5 rounded-xl bg-slate-800 border border-slate-700 transition text-left text-slate-300";
          star.innerText = "☆";
          star.className = "star-badge text-slate-500 text-sm";
        }
      });

      // 更新得分
      document.getElementById('score-counter').innerText = activeSet.size;

      // 檢查是否全部完成 (10個單字)
      if (activeSet.size === 10) {
        triggerUltimateVictory();
      }
    }

    // 模式切換器
    function setGameMode(mode) {
      gameMode = mode;
      
      // 切換選單 Tab 樣式 (外框統一用藍色，未按下時是淺色底，按下時才是黑底)
      const tabs = ['challenge', 'listening'];
      tabs.forEach(t => {
        const el = document.getElementById(`tab-${t}`);
        if (t === mode) {
          el.className = "flex-1 flex items-center justify-center gap-2 py-3 px-6 rounded-2xl border-4 font-black transition-all shadow-md text-base sm:text-lg bg-slate-900 border-blue-600 text-white scale-105 shadow-blue-200/50";
        } else {
          el.className = "flex-1 flex items-center justify-center gap-2 py-3 px-6 rounded-2xl border-4 font-black transition-all text-base sm:text-lg bg-blue-50/50 border-blue-300 text-blue-700 hover:bg-blue-100/50 hover:scale-102";
        }
      });

      // 更新主面板樣式
      const badge = document.getElementById('mode-badge');
      if (mode === 'challenge') {
        badge.innerText = "看圖猜字模式";
        badge.className = "text-xs font-bold px-2.5 py-1 rounded-lg bg-orange-100 text-orange-700";
      } else {
        badge.innerText = "聽音測試模式";
        badge.className = "text-xs font-bold px-2.5 py-1 rounded-lg bg-teal-100 text-teal-700";
      }

      renderInteractivePanel();
      updateChecklistUI();
      updateFlapDisplay(false);
    }

    // 渲染右側互動控制面板內容 (藍框黑底卡)
    function renderInteractivePanel() {
      const panel = document.getElementById('mode-interactive-panel');
      
      if (gameMode === 'challenge') {
        const target = challengeList[challengeWordIndex];
        panel.innerHTML = `
          <div onclick="speakChallengeTranslation()" class="cursor-pointer bg-slate-900 border-4 border-blue-600 rounded-3xl py-6 px-8 shadow-2xl flex flex-col items-center justify-center max-w-sm mx-auto active:scale-95 transition-transform group">
            <span class="text-6xl group-hover:scale-110 transition-transform">${target.emoji}</span>
            <span class="text-4xl font-black text-white mt-3 tracking-wider">${target.translation}</span>
            <span class="text-[11px] text-blue-400 font-bold mt-2">點擊聽題目中文 🔊</span>
          </div>
        `;
      } 
      else if (gameMode === 'listening') {
        panel.innerHTML = `
          <div onclick="playListeningAudio()" class="cursor-pointer bg-slate-900 border-4 border-blue-600 rounded-3xl py-8 px-12 shadow-2xl flex flex-col items-center justify-center max-w-sm mx-auto active:scale-95 transition-transform group">
            <span class="text-6xl text-white group-hover:scale-110 transition-transform">🔊</span>
            <span class="text-2xl font-black text-white mt-4 tracking-widest">播放題目英文</span>
            <span class="text-[11px] text-blue-400 font-bold mt-2">點擊聽聲音 🔊</span>
          </div>
        `;
      }
    }

    // 挑戰模式中文題目發音
    function speakChallengeTranslation() {
      const target = challengeList[challengeWordIndex];
      speakCustomText(target.translation);
    }

    function nextChallenge() {
      if (challengeWordIndex < challengeList.length - 1) {
        challengeWordIndex++;
        renderInteractivePanel();
        updateFlapDisplay(false);
      } else {
        // 完成全部 10 關挑戰！
        triggerUltimateVictory();
        resetAllProgress();
      }
    }

    // 聽力模式播放
    function playListeningAudio() {
      const target = listeningList[listeningWordIndex];
      if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        const speed = parseFloat(document.getElementById('voice-speed').value) || 0.7;
        const utter = new SpeechSynthesisUtterance(target.full);
        utter.lang = 'en-US';
        utter.rate = speed;
        window.speechSynthesis.speak(utter);
      }
    }

    function nextListening() {
      if (listeningWordIndex < listeningList.length - 1) {
        listeningWordIndex++;
        renderInteractivePanel();
        updateFlapDisplay(false);
      } else {
        // 聽力全部通關！
        triggerUltimateVictory();
        resetAllProgress();
      }
    }

    // 重設遊戲狀態
    function resetAllProgress() {
      challengeCompletedSet.clear();
      listeningCompletedSet.clear();
      challengeWordIndex = 0;
      listeningWordIndex = 0;
      initGame();
      updateChecklistUI();
      closeVictoryModal();
      setGameMode('challenge');
    }

    // 觸發勝利撒花
    function triggerUltimateVictory() {
      playVictorySound();
      for (let i = 0; i < 4; i++) {
        setTimeout(() => {
          createConfettiExplosion(80);
        }, i * 600);
      }

      const modal = document.getElementById('victory-modal');
      const content = document.getElementById('victory-content');
      modal.classList.remove('opacity-0', 'pointer-events-none');
      content.classList.remove('scale-90');
    }

    function closeVictoryModal() {
      const modal = document.getElementById('victory-modal');
      const content = document.getElementById('victory-content');
      modal.classList.add('opacity-0', 'pointer-events-none');
      content.classList.add('scale-90');
    }

    // ==========================================
    // 純 HTML5 CANVAS 撒花粒子系統 (無第三方依賴)
    // ==========================================
    const canvas = document.getElementById('confetti-canvas');
    const ctx = canvas.getContext('2d');
    let particles = [];
    let animationFrameId = null;

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    class ConfettiParticle {
      constructor(x, y) {
        this.x = x;
        this.y = y;
        this.size = Math.random() * 8 + 4;
        this.color = `hsl(${Math.random() * 360}, 100%, 60%)`;
        this.speedX = Math.random() * 10 - 5;
        this.speedY = Math.random() * -12 - 5;
        this.gravity = 0.3;
        this.rotation = Math.random() * 360;
        this.rotationSpeed = Math.random() * 4 - 2;
        this.opacity = 1;
      }

      update() {
        this.speedY += this.gravity;
        this.x += this.speedX;
        this.y += this.speedY;
        this.rotation += this.rotationSpeed;
        this.opacity -= 0.015;
      }

      draw() {
        ctx.save();
        ctx.translate(this.x, this.y);
        ctx.rotate((this.rotation * Math.PI) / 180);
        ctx.globalAlpha = this.opacity;
        ctx.fillStyle = this.color;
        if (this.size > 8) {
          ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
        } else {
          ctx.beginPath();
          ctx.arc(0, 0, this.size / 2, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.restore();
      }
    }

    function createConfettiExplosion(count = 50) {
      const startX = Math.random() * (canvas.width * 0.6) + canvas.width * 0.2;
      const startY = canvas.height + 10;
      for (let i = 0; i < count; i++) {
        particles.push(new ConfettiParticle(startX, startY));
      }
      if (!animationFrameId) {
        animateParticles();
      }
    }

    function animateParticles() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (let i = particles.length - 1; i >= 0; i--) {
        particles[i].update();
        particles[i].draw();
        if (particles[i].opacity <= 0 || particles[i].y > canvas.height + 20) {
          particles.splice(i, 1);
        }
      }
      if (particles.length > 0) {
        animationFrameId = requestAnimationFrame(animateParticles);
      } else {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    }
  </script>
