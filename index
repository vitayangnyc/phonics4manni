  <!-- 全通關超級成就彈窗 (Modal) -->
  <div id="victory-modal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-md flex items-center justify-center z-50 p-4 opacity-0 pointer-events-none transition-all duration-500">
    <div class="bg-white rounded-3xl max-w-md w-full p-8 text-center shadow-2xl border-4 border-amber-400 scale-90 transition-transform duration-500" id="victory-content">
