      <div class="lg:col-span-5 flex flex-col gap-6">
        
        <!-- 單字速查進度表（與圖片10個單字完全一致） -->
        <div class="bg-slate-900 text-white rounded-3xl p-6 shadow-xl relative">
          <div class="absolute top-4 right-4 text-xs font-extrabold text-indigo-400 bg-slate-800 px-2 py-1 rounded">
